---
import { Building2 } from "lucide-astro"
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import PageLayout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
const jobGroups = await getCollection("jobs");

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/*.{jpeg,jpg,png,webp,avif}",
  { eager: true }
);

const imageMap = new Map<string, ImageMetadata>();
for (const [path, mod] of Object.entries(imageModules)) {
  const filename = path.split("/").pop()!;
  imageMap.set(filename, mod.default);
}

const meta = {
  title: 'Rob McGuinness Personal Website',
  description:
    "Articles and thoughts on web development, JavaScript, and developer experience.",
};

---

<PageLayout meta={meta}>
  <section class="py-12 md:py-16">
    <h1 class="text-4xl font-bold mb-8 text-wrap-balance">Rob McGuinness</h1>
    <p class="text-xl md:text-2xl max-w-2xl">
      An engineering leader passionate about building high-performing teams with a strong focus on developer experience, clean architecture and maintainable code.
    </p>
  </section>
  <section>
    <h2 class="text-3xl font-bold mb-8 text-wrap-balance">Work Experience</h2>
    <div class="space-y-8">
      {
        jobGroups.map((jobGroup) => {
          const { company, positions, logo } = jobGroup.data;
          const logoImage = logo ? imageMap.get(logo) : undefined;

          return (
            <div>
              <div class="flex items-center gap-3 mb-4">
                {logoImage ? (
                  <Image src={logoImage} alt={company + ' logo'} width={32} height={32} class="w-8 h-8" />
                ) : (
                  <Building2 class="w-5 h-5 text-gray-400" aria-hidden="true" />
                )}
                <h3 class="text-lg font-medium">{company}</h3>
              </div>

              <div class="ml-11 space-y-2">
                {positions.map((position) => (
                  <div>
                    <h4 class="font-medium">{position.title}</h4>
                    <span class="text-sm text-gray-500 dark:text-gray-400">
                      {position.from} – {position.to}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </section>
</PageLayout>
