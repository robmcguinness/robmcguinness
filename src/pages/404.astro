---
import PageLayout from "../layouts/Layout.astro";

const meta = {
  title: "Page Not Found",
  description: "The page you're looking for doesn't exist.",
  noindex: true,
};
---

<PageLayout {meta}>
  <section class="py-24 text-center">
    <h1 class="text-6xl font-bold mb-4">404</h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">
      The page you're looking for doesn't exist.
    </p>
    <a
      href="/"
      class="inline-flex items-center px-4 py-2 text-lg font-medium rounded-md bg-orange-500 text-white no-underline hover:bg-orange-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-orange-500 focus-visible:ring-offset-2"
    >
      Go home
    </a>
  </section>
</PageLayout>
