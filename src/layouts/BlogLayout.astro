---
import { SITE_TITLE } from "@/constants.mjs";
import Layout from "./Layout.astro";

const { frontmatter } = Astro.props;

const meta = {
  title: `${frontmatter.title} | ${SITE_TITLE}`,
  description: frontmatter.description,
  image: frontmatter.image,
  ogType: "article",
};

const formattedDate = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
}).format(new Date(frontmatter.publishDate));
---

<Layout {meta}>
  <article class="py-12 md:py-16">
    <header class="mb-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-wrap-balance">
        {frontmatter.title}
      </h1>

      <p class="text-xl text-gray-600 dark:text-gray-300 mb-4">
        {frontmatter.description}
      </p>

      <time
        datetime={frontmatter.publishDate.toISOString()}
        class="text-sm text-gray-500 dark:text-gray-400"
      >
        {formattedDate}
      </time>
      {
        frontmatter.tags && frontmatter.tags.length > 0 && (
          <span class="text-sm text-gray-500 dark:text-gray-400 ml-2">
            · {frontmatter.tags.join(", ")}
          </span>
        )
      }
    </header>

    {
      frontmatter.image && (
        <div class="mb-8 overflow-hidden">
          <img
            src={frontmatter.image}
            alt={`Cover image for ${frontmatter.title}`}
            class="w-full h-auto"
            width={1200}
            height={630}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      )
    }

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <slot />
    </div>
  </article>
</Layout>
